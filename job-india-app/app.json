{
  "expo": {
    "name": "Kishan Solution",
    "slug": "job-india",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to show nearby jobs.",
        "NSCameraUsageDescription": "Camera is used for document uploads.",
        "NSPhotoLibraryUsageDescription": "Photo library is used for document uploads."
      }
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDnyLLiPykuaRbCKZEmBPa0jzdiB61qRpc"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.hbsdevelopersteam.jobindia",
      "googleServicesFile": "./google-services.json",
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE"
      ],
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-build-properties",
      [
        "expo-notifications",
        {
          "icon": "./assets/favicon.png",
          "color": "#2563EB"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo-google-fonts/inter/900Black/Inter_900Black.ttf"
          ]
        }
      ],
      "expo-image",
      "expo-secure-store",
      "expo-status-bar",
      "@react-native-community/datetimepicker",
      "expo-sharing"
    ],
    "extra": {
      "apiUrl": "https://jobapi.adsdigitalmedia.com/api/v1"
    }
  }
}
