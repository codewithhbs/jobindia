NODE_ENV=development
PORT=4000
SERVICE_NAME=job-marketplace-backend
BASE_URL=https://jobapi.adsdigitalmedia.com

# ───── Database ─────
MONGODB_URI=mongodb://localhost:27017/jobmarketplace

# ───── Redis (optional — sessions/cache; app runs without it) ─────
REDIS_URL=redis://localhost:6379

# ───── Notification queue (BullMQ — uses REDIS_URL above) ─────
# Worker concurrency for draining the notification queue.
NOTIFICATION_CONCURRENCY=5
# Cron for the daily plan-expiry scan (default: 09:00 every day).
PLAN_EXPIRY_CRON=0 9 * * *

# ───── JWT ─────
JWT_SECRET=change_this_super_secret_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ───── OTP ─────
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
OTP_RATE_LIMIT_WINDOW=15
OTP_RATE_LIMIT_MAX=5
# comma separated test numbers that always get 123456 and skip SMS
OTP_TEST_NUMBERS=+917217619794,+918287229430

# ───── Twilio (SMS OTP) ─────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ───── AWS S3 (media uploads — optional, falls back to local disk) ─────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=jobmarket-uploads
CDN_URL=https://your-cdn.cloudfront.net

# ───── Logging ─────
LOG_LEVEL=info

# ───── Razorpay (payments — optional; without keys a dev mock order is returned) ─────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
